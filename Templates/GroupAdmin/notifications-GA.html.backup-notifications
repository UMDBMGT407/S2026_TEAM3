<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="../../Static/CSS/vars.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="../../Static/CSS/notifications-GA.css">
  <title>Notifications</title>
</head>
<body>
  <div class="nga-layout container-fluid p-0">
    <div class="row g-0 min-vh-100">
      <aside class="col-12 col-md-3 col-xl-2 nga-sidebar">
        <div class="nga-sidebar-inner">
          <img class="nga-logo" src="../../Static/images/NGAmotiv-logo1.png" alt="Motiv logo" />
          <nav class="nga-nav" aria-label="Main navigation">
            <a href="GADash.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector0.svg" alt="" /><span>Dashboard</span></a>
            <a href="created-groups-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector1.svg" alt="" /><span>Groups</span></a>
            <a href="scheduling-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector2.svg" alt="" /><span>Scheduling</span></a>
            <a href="created-challenges-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector3.svg" alt="" /><span>Challenges</span></a>
            <a href="post-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector4.svg" alt="" /><span>Posts</span></a>
            <a href="workout-history-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector-log0.svg" alt="" /><span>Workout Log</span></a>
            <a href="profile-GA.html" class="nga-nav-link"><img class="nga-nav-icon" src="../../Static/images/NGAvector-profile-icon0.svg" alt="" /><span>Profile</span></a>
          </nav>
        </div>
      </aside>

      <div class="col-12 col-md-9 col-xl-10 nga-main d-flex flex-column">
        <header class="nga-topbar">
          <h1 class="nga-page-title">Notifications</h1>
          <div class="nga-topbar-actions">
            <a href="notifications-GA.html" class="nga-notify-btn" aria-label="Notifications">
              <span class="nga-notify-bg"></span>
              <img class="nga-notify-icon" src="../../Static/images/NGA_002-notification-10.svg" alt="" />
            </a>
            <img class="nga-avatar" src="../../Static/images/NGAprofile-picture1.png" alt="Profile picture" />
          </div>
        </header>

        <main class="nga-main-canvas flex-grow-1">
          <section class="nga-card">
            <div class="nga-head-row">
              <span>Invites</span>
              <span>Actions</span>
            </div>

            <div class="nga-invites">
              <article class="nga-invite-row">
                <p class="nga-invite-label">Group Name 1</p>
                <div class="nga-actions">
                  <button class="nga-action-btn" type="button">Accept</button>
                  <button class="nga-action-btn" type="button">Reject</button>
                </div>
              </article>

              <article class="nga-invite-row">
                <p class="nga-invite-label">Group 1 : Challenge Name</p>
                <div class="nga-actions">
                  <button class="nga-action-btn" type="button">Accept</button>
                  <button class="nga-action-btn" type="button">Reject</button>
                </div>
              </article>

              <article class="nga-invite-row">
                <p class="nga-invite-label">Group Name 2</p>
                <div class="nga-actions">
                  <button class="nga-action-btn" type="button">Accept</button>
                  <button class="nga-action-btn" type="button">Reject</button>
                </div>
              </article>

              <article class="nga-invite-row">
                <p class="nga-invite-label">Group Name : Challenge Name</p>
                <div class="nga-actions">
                  <button class="nga-action-btn" type="button">Accept</button>
                  <button class="nga-action-btn" type="button">Reject</button>
                </div>
              </article>

              <article class="nga-invite-row">
                <p class="nga-invite-label">Group Name 5</p>
                <div class="nga-actions">
                  <button class="nga-action-btn" type="button">Accept</button>
                  <button class="nga-action-btn" type="button">Reject</button>
                </div>
              </article>
            </div>
          </section>
        </main>
      </div>
    </div>
  </div>
</body>
</html>